{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": ["NEXT_PUBLIC_API_BASE_URL", "API_BASE_URL"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "test": {
      "outputs": ["coverage/**"]
    },
    "test:coverage": {
      "outputs": ["coverage/**"]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "outputs": ["apps/web/test-results/**", "apps/web/playwright-report/**"],
      "env": ["DATABASE_URL", "NEXT_PUBLIC_API_BASE_URL", "BASE_URL"]
    },
    "quality-gate": {
      "dependsOn": ["^build"],
      "outputs": ["apps/web/test-results/**", "apps/web/playwright-report/**"],
      "env": [
        "SKIP_PW_WEBSERVER",
        "BASE_URL",
        "DATABASE_URL",
        "NEXT_PUBLIC_API_BASE_URL"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
