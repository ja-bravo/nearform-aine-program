# Copy to `.env` in the repo root for docker compose variable substitution.
# Production: terminate TLS at the edge; browsers must use HTTPS to reach the API (see README).

# Postgres (used by API and docker-compose postgres service)
POSTGRES_USER=todo
POSTGRES_PASSWORD=todo
POSTGRES_DB=todo

# API (Fastify)
API_PORT=3001
API_HOST=0.0.0.0
# Comma-separated browser origins allowed for CORS (web app origin). Default matches WEB_PORT=3000.
CORS_ORIGIN=http://localhost:3000
# Local dev (host machine): postgresql://todo:todo@localhost:5432/todo
# In compose, the API service overrides this to reach the `postgres` hostname.
DATABASE_URL=postgresql://todo:todo@localhost:5432/todo

# Test Postgres (--profile test, service postgres_test; vars separate from dev POSTGRES_*)
# POSTGRES_TEST_PORT=5433
# POSTGRES_TEST_USER=todo
# POSTGRES_TEST_PASSWORD=todo
# POSTGRES_TEST_DB=todo_test
# DATABASE_URL_TEST=postgresql://todo:todo@localhost:5433/todo_test

# Web (Next.js)
WEB_PORT=3000
# Browser-visible API base URL. Local HTTP is OK; production must be HTTPS (NFR4).
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
# Optional: URL the Next.js server uses to call the API (SSR). Defaults to NEXT_PUBLIC_API_BASE_URL.
# In Docker Compose the web service sets this to http://api:<API_PORT> automatically.
# API_BASE_URL=